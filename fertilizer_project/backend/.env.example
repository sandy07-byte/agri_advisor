# Backend Environment Variables
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/agriadvisor
JWT_SECRET=your-super-secret-jwt-key-change-in-production
PORT=8000

# Weather API (OpenWeatherMap) - Get key from https://openweathermap.org/api
OPENWEATHER_API_KEY=your-openweathermap-api-key

# Mandi Market API (data.gov.in) - Get key from https://data.gov.in/
MANDI_API_KEY=your-data-gov-in-api-key
